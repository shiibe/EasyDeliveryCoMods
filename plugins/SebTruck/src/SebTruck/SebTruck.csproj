<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>SebTruck</AssemblyName>
    <RootNamespace>SebTruck</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="BepInEx">
      <HintPath>$(BepInExCoreDir)\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(BepInExCoreDir)\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="UnityEngine">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\UnityEngine.InputLegacyModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UIModule">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\UnityEngine.UIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="UnityEngine.PhysicsModule">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\UnityEngine.PhysicsModule.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <!-- Intentionally no UnityEngine.AudioModule reference: use reflection for ignition SFX. -->

    <Reference Include="Assembly-CSharp">
      <HintPath>$(GameDir)\EasyDeliveryCo_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <ProjectReference Include="..\..\..\SebCore\src\SebCore\SebCore.csproj" />
    <ProjectReference Include="..\..\..\SebBinds\src\SebBinds\SebBinds.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Include ignition SFX in build output so packaging can pick it up. -->
    <Content Include="sfx\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    
    <!-- Keep a dedicated item list for the r2modman profile copy target. -->
    <TruckSfx Include="sfx\**\*" />

    <!-- Custom emissive maps for indicators. -->
    <Content Include="emissives\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>

    <!-- Keep a dedicated item list for the r2modman profile copy target. -->
    <TruckEmissives Include="emissives\**\*" />
  </ItemGroup>

  <Target Name="CopyToR2ModmanProfile" AfterTargets="Build">
    <MakeDir Directories="$(ProfileDir)\BepInEx\plugins\SebTruck" />
    <Copy
      SourceFiles="$(TargetDir)$(AssemblyName).dll"
      DestinationFolder="$(ProfileDir)\BepInEx\plugins\SebTruck"
      SkipUnchangedFiles="true" />
    <Copy
      SourceFiles="$(TargetDir)$(AssemblyName).pdb"
      DestinationFolder="$(ProfileDir)\BepInEx\plugins\SebTruck"
      SkipUnchangedFiles="true"
      Condition="Exists('$(TargetDir)$(AssemblyName).pdb')" />

    <Copy
      SourceFiles="@(TruckSfx)"
      DestinationFiles="@(TruckSfx->'$(ProfileDir)\BepInEx\plugins\SebTruck\sfx\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Condition="@(TruckSfx) != ''" />

    <Copy
      SourceFiles="@(TruckEmissives)"
      DestinationFiles="@(TruckEmissives->'$(ProfileDir)\BepInEx\plugins\SebTruck\emissives\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Condition="@(TruckEmissives) != ''" />
  </Target>

</Project>
